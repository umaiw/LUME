# ── LUME Docker Environment ──
# Copy to .env and configure before running: docker compose up -d

# ═══════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════

# Secret for WebSocket JWT tokens. Must be at least 32 bytes.
# Generate with: openssl rand -base64 48
WS_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES

# ═══════════════════════════════════════
# CLIENT (baked into build)
# ═══════════════════════════════════════

# Public-facing URLs the browser uses to reach the server.
# For local/self-hosted: use http://localhost:3001 or your LAN IP.
# For production behind a reverse proxy: use your domain.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# ═══════════════════════════════════════
# SERVER
# ═══════════════════════════════════════

# Host ports (mapped to container ports 3001 and 3000)
SERVER_PORT=3001
CLIENT_PORT=3000

# CORS allowlist for the client origin (comma-separated)
CLIENT_ORIGIN=http://localhost:3000

# Set to 1 when behind a trusted reverse proxy (Nginx, Caddy, etc.)
TRUST_PROXY=0
WS_TRUST_PROXY=0

# Request body size limit
JSON_LIMIT=256kb

# WebSocket max message size in bytes
WS_MAX_PAYLOAD_BYTES=65536

# Logging (set to 1 to enable)
LOG_HTTP=0
LOG_SECURITY=0
